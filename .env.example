# ===========================================================================
# Aegis AI Governance Platform — sample environment for LOCAL DEVELOPMENT / DEMO.
# Copy to .env (which is git-ignored): cp .env.example .env
#
# AEGIS_ENV=development relaxes the production secret-strength guard so the demo
# boots with placeholder secrets. For real deployments set AEGIS_ENV=production
# and inject strong secrets via your orchestrator / Vault / KMS — the app will
# refuse to start with any "change-me" secret when AEGIS_ENV=production.
# ===========================================================================

# Core
AEGIS_ENV=development
AEGIS_PUBLIC_BASE_URL=http://localhost:8080
AEGIS_LOG_LEVEL=INFO
AEGIS_LOG_JSON=true

# Database
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_dev_password_change_me
POSTGRES_DB=aegis
DATABASE_URL=postgresql://aegis:aegis_dev_password_change_me@postgres:5432/aegis
AEGIS_DB_POOL_MIN=1
AEGIS_DB_POOL_MAX=10

# Identity / OIDC
OIDC_ISSUER=http://keycloak:8080/realms/aegis
OIDC_PUBLIC_ISSUER=http://localhost:8081/realms/aegis
OIDC_AUDIENCE=aegis-api
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_change_me
# Keycloak (production mode) persists users/realm in Postgres -> a dedicated `keycloak`
# database on the same Postgres instance, reusing POSTGRES_USER/POSTGRES_PASSWORD above.
# Created automatically on a fresh postgres_data volume (deploy/postgres/01-keycloak-db.sql);
# for an existing volume create it once:
#   docker compose exec postgres psql -U "$POSTGRES_USER" -d "$POSTGRES_DB" -c "CREATE DATABASE keycloak;"

# Authorization (OPA PDP)
OPA_URL=http://opa:8181
OPA_PACKAGE=aegis.authz
AEGIS_REQUIRE_OPA=true

# Admin surface (bootstrap, audit chain verification)
AEGIS_ADMIN_TOKEN=change-me-admin-token

# Secrets backend
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root-dev-token-change-me
AEGIS_SECRET_BACKEND=vault
AEGIS_SECRET_ENV_FALLBACK=true

# Audit encryption and hash chain
AEGIS_LOCAL_MASTER_KEY=dev-local-master-key-change-me-32bytes
AEGIS_AUDIT_KEY=
AEGIS_ENCRYPT_AUDIT=true

# Skill manifest signing (demo HMAC; replace with Sigstore/KMS in production)
AEGIS_SKILL_SIGNING_KEY=demo-skill-signing-key
AEGIS_REQUIRE_SKILL_SIGNATURE=true

# Model routing defaults
AEGIS_DEFAULT_MODEL=openai/gpt-4.1
AEGIS_MODEL_REGION=AC1
AEGIS_MODEL_TIMEOUT_SECONDS=90
AEGIS_MODEL_MAX_RETRIES=2
AEGIS_MODEL_MAX_OUTPUT_TOKENS=4096

# ---- Hosted model providers (this deployment ships three; no local/Ollama) ----
# Provide all three keys at setup even though gpt-4.1 is the default, so the platform admin can
# switch the live default to any of them from the Models console tab without a redeploy.

# OpenAI (default model: openai/gpt-4.1)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# NVIDIA build (model: nvidia/nemotron-3-super-120b-a12b)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=

# Anthropic (model: anthropic/claude-sonnet-4-6)
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# Runtime cells
AEGIS_RUNTIME_BACKEND=docker
AEGIS_RUNTIME_IMAGE=aegis-runtime-cell:latest
AEGIS_RUNTIME_NETWORK=none
AEGIS_RUNTIME_CPU_QUOTA=100000
AEGIS_RUNTIME_MEMORY_LIMIT=512m
AEGIS_RUNTIME_TIMEOUT_SECONDS=60

# Rate limiting
AEGIS_RATE_LIMIT_ENABLED=true
AEGIS_RATE_LIMIT_PER_MINUTE=60

# OpenTelemetry
OTEL_SERVICE_NAME=aegis-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Distributed rate limiting (memory | redis)
AEGIS_RATE_LIMIT_BACKEND=redis
AEGIS_REDIS_URL=redis://redis:6379/0

# Skill signing (Ed25519 public key, base64 raw bytes; demo key)
AEGIS_SKILL_PUBLIC_KEY=Ms5VAI+2S9EJZZSGcV/EPwAyvpx/RGbRELjcIrfgGc8=

# Semantic memory (opt-in; needs an embedding model, e.g. `ollama pull nomic-embed-text`)
AEGIS_EMBED_ENABLED=false
AEGIS_EMBED_BASE=http://host.docker.internal:11434
AEGIS_EMBED_MODEL=nomic-embed-text
AEGIS_EMBED_DIM=768
