# .env.prod.example -- append these to .env when Aegis runs behind a real public
# hostname (e.g. https://aegis.<host>.sslip.io). Without them the api will
# reject every login with "invalid token: Invalid issuer".
#
# What each one controls:
#   AEGIS_PUBLIC_HOSTNAME  the public DNS name the SPA loads from. Caddy auto-
#                        issues a Let's Encrypt cert for it and listens on 443.
#   OIDC_PUBLIC_ISSUER   the api validates JWT `iss` claims against this. Must
#                        be the public URL Keycloak hands out tokens for.
#   AEGIS_CORS_ORIGINS     browser CORS preflight gate. Must include the public
#                        origin the SPA is loaded from.
#   OIDC_ISSUER          in-cluster URL the api uses to talk to Keycloak.
#                        Only override for split-host deployments.
#
# Replace <your-host> below with your actual hostname.

AEGIS_PUBLIC_HOSTNAME=aegis.<your-host>.sslip.io
OIDC_PUBLIC_ISSUER=https://aegis.<your-host>.sslip.io/realms/aegis
AEGIS_CORS_ORIGINS=https://aegis.<your-host>.sslip.io

# Uncomment only for split-host deployments:
# OIDC_ISSUER=https://aegis.<your-host>.sslip.io/realms/aegis
