# Aegis production env file.
#
# Copy to /etc/aegis/env on the VM (chmod 600). NEVER commit the real one.
#
# DOMAIN is auto-set by deploy.sh from the VM's public IP. Everything else
# you fill in once before the first deploy.

# ============================================================
# Public URL — auto-populated by deploy.sh as aegis-<ip>.nip.io
# ============================================================
DOMAIN=
ACME_EMAIL=you@example.com         # Let's Encrypt registration email

# ============================================================
# Provider keys (the chat needs these)
# ============================================================
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...     # optional, only if you switch model
# GOOGLE_API_KEY=AI...             # optional

# ============================================================
# Aegis platform secrets (rotate these for each deploy)
# ============================================================
AEGIS_ADMIN_TOKEN=                 # 32+ random chars; ops override
AEGIS_LOCAL_MASTER_KEY=            # 32 chars exactly, hex
AEGIS_AUDIT_KEY=                   # 32 chars hex; encrypts audit payloads
AEGIS_SKILL_SIGNING_KEY=           # Ed25519 private key, base64 (gen via scripts/sign-skill.py)
AEGIS_SKILL_PUBLIC_KEY=            # matching public key, base64

# ============================================================
# Datastore credentials (the VM is the only thing that talks to these)
# ============================================================
POSTGRES_USER=aegis
POSTGRES_PASSWORD=                 # 24+ random chars
POSTGRES_DB=aegis

# ============================================================
# Keycloak admin (used by the bootstrap script to create test users)
# ============================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=           # strong random; you'll need this to log into the KC admin UI

# ============================================================
# Vault — kept in the cluster for parity with the local stack
# ============================================================
VAULT_TOKEN=                       # 32+ random chars
